// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  spotifyId String?  @unique
  name      String?
  refreshToken String?
  spotifyToken String?           // Spotify API access token (for calling Spotify APIs)
  spotifyRefreshToken String?     // Spotify refresh token (for refreshing Spotify access token)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albumSurveys         AlbumSurvey[]
  recommendations      Recommendation[]
  tasteProfile         UserTasteProfile?
  recommendationFeedback RecommendationFeedback[]
  
  perceptionDimensions UserAlbumPerceptionDimension[]
}

model Album {
  id        String   @id @default(uuid())

  title     String
  artist    String
  imageUrl  String?

  // ─────────────────────────────────────────────────────────────────────
  // METADATA & CATALOG DISCOVERY
  // lastFmTags: Persisted Last.fm tag extraction result
  // embeddingSource: Marks how embedding was derived
  // ─────────────────────────────────────────────────────────────────────
  lastFmTags        Json?                    // Persisted tags from Last.fm (tag name + count)
  
  embeddingDerivedFrom     String? @default("lastfmTags")  // lastfmTags|audio|clap
  embeddingConfidence      Float? @default(0.5)
  embeddingSourceMetadata  Json?  // { tagCount, topTags[], confidence, timestamp }
  enrichmentStatus         String? @default("pending")     // pending|enriched|embedded
  
  // ─────────────────────────────────────────────────────────────────────
  // LIFECYCLE TRACKING (for worker orchestration)
  // ─────────────────────────────────────────────────────────────────────
  lastDiscoveredAt   DateTime?  // When this album was last discovered by workers
  embeddingComputedAt DateTime? // When embedding was last computed
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  externalIds        AlbumExternalId[]
  recommendations    Recommendation[]
  albumSurveys       AlbumSurvey[]
  recommendationFeedback RecommendationFeedback[]
  userAlbumPerceptions   UserAlbumPerceptionDimension[]
  intrinsicProfileDimensions AlbumIntrinsicProfileDimension[]
}

model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  lat         Float
  lon         Float
  generatedAt DateTime @default(now())

  @@index([userId, generatedAt])
  @@index([albumId])
}

model AlbumSurvey {
  id        String @id @default(cuid())
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId   String
  album     Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model Dimension {
  id          String @id @default(cuid())
  name        String @unique
  label       String
  description String
  leftLabel   String
  rightLabel  String
  
  userAlbumPerceptions UserAlbumPerceptionDimension[]
  albumProfiles AlbumIntrinsicProfileDimension[]
  userProfiles UserTasteProfileDimension[]
}

model UserAlbumPerceptionDimension {
  id          String @id @default(cuid())
  
  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId     String
  album       Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  dimensionId String
  dimension   Dimension @relation(fields: [dimensionId], references: [id])
  
  value       Int  // 0-100
  
  @@unique([userId, albumId, dimensionId])
}

model UserTasteProfile {
  id             String @id @default(cuid())
  userId         String @unique
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumsAnalyzed Int @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  dimensions UserTasteProfileDimension[]
}

model UserTasteProfileDimension {
  id          String @id @default(cuid())
  
  userProfileId String
  userProfile   UserTasteProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  dimensionId String
  dimension   Dimension @relation(fields: [dimensionId], references: [id])
  
  value       Float  // 0-1 (final merged value, no bias)
  
  @@unique([userProfileId, dimensionId])
}

model AlbumIntrinsicProfileDimension {
  id          String @id @default(cuid())
  
  albumId     String
  album       Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  dimensionId String
  dimension   Dimension @relation(fields: [dimensionId], references: [id])
  
  value       Float  // 0-1
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([albumId, dimensionId])
}

// ═════════════════════════════════════════════════════════════════════════
// RECOMMENDATION FEEDBACK
// 
// Tracks what happens when recommendations are given.
// Essential for validation and behavioral learning.
// 
// Stored when recommendation is generated, updated when user listens.
// ═════════════════════════════════════════════════════════════════════════
model RecommendationFeedback {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId             String
  album               Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  recommendationId    String   // Reference to Recommendation table
  
  // ─────────────────────────────────────────────────────────────────────
  // LISTENING BEHAVIOR (updated when user listens)
  // ─────────────────────────────────────────────────────────────────────
  listeningDuration   Int?     // seconds
  completed           Boolean? // did user finish album?
  skipped             Boolean? // did user skip?
  saved               Boolean? // did user favorite?
  
  // ─────────────────────────────────────────────────────────────────────
  // CONTEXT AT TIME OF RECOMMENDATION
  // Used to correlate: does context actually improve recommendations?
  // ─────────────────────────────────────────────────────────────────────
  contextData         Json     // { temperature, humidity, cloudiness, timeOfDay, season, ... }
  
  // User's reported mood/context when recommendation was made (optional)
  userReportedContext String?  // "focus", "relaxation", "walking", "nighttime", etc.
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId, recommendationId])
  @@index([userId, createdAt])
  @@index([albumId])
}

// ═════════════════════════════════════════════════════════════════════════════
// CATALOG DECOUPLING - NEW MODELS (PHASE 1 REFACTOR)
// ═════════════════════════════════════════════════════════════════════════════

// AlbumExternalId: Track same album across multiple providers (Spotify, Last.fm, etc.)
// Supports future migration to other sources without breaking album identity
model AlbumExternalId {
  id                String   @id @default(cuid())
  
  albumId           String
  album             Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  provider          String   // spotify|lastfm|musicbrainz|clap
  externalId        String   // Provider's ID for this album
  providerMetadata  Json?    // Additional metadata from provider (e.g., Spotify URI, Last.fm URL)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([albumId, provider])
  @@index([provider, externalId])
  @@index([albumId])
}

// ProcessingJob: Track background worker job executions
// Used by catalog discovery/enrichment/embedding workers (Phase 2)
// Provides job history for debugging and retry logic
model ProcessingJob {
  id              String   @id @default(cuid())
  
  jobType         String   // discover|enrich|embed|refresh_catalog
  status          String   // pending|running|completed|failed|retrying
  
  // Job metadata
  batchId         String?  // For grouping related jobs (e.g., nightly run)
  targetCount     Int?     // Expected items to process
  processedCount  Int?     // Items actually processed
  
  // Results & errors
  result          Json?    // Job-specific result data
  errorMessage    String?  // Error details if failed
  errorStack      String?  // Full stack trace if failed
  
  // Retry tracking
  attemptNumber   Int @default(1)
  maxAttempts     Int @default(3)
  
  // Lifecycle
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([jobType, status])
  @@index([jobType, createdAt])
  @@index([batchId])
  @@index([status])
}

// LastFmProfile: Cache artist-level Last.fm embeddings (optional, for performance)
// Reduces repeated Last.fm API calls for artist embeddings
// TTL: 48h refresh
model LastFmProfile {
  id              String   @id @default(cuid())
  
  artistName      String @unique
  
  embedding       Float[]  // 7D vector (stored as array in JSON/BYTEA depending on DB)
  
  tagSources      Int?     // Number of albums used to compute this embedding
  confidence      Float?   // Confidence score [0, 1]
  
  lastUpdatedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([artistName])
}

