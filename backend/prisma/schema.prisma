// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  spotifyId String?  @unique
  name      String?
  refreshToken String?
  spotifyToken String?           // Spotify API access token (for calling Spotify APIs)
  spotifyRefreshToken String?     // Spotify refresh token (for refreshing Spotify access token)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albumSurveys         AlbumSurvey[]
  recommendations      Recommendation[]
  tasteProfile         UserTasteProfile?
  recommendationFeedback RecommendationFeedback[]
}

model Album {
  id        String   @id @default(uuid())
  spotifyId String   @unique
  title     String
  artist    String
  imageUrl  String?
  spotifyUrl String?

  recommendations        Recommendation[]
  albumSurveys          AlbumSurvey[]
  emotionalEmbedding    AlbumEmotionalEmbedding?
  recommendationFeedback RecommendationFeedback[]
}

model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  lat         Float
  lon         Float
  generatedAt DateTime @default(now())

  @@index([userId, generatedAt])
  @@index([albumId])
}

model AlbumSurvey {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId          String
  album            Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  // PHASE 1: Experiential survey responses (0-100 scale, 7D dimensions)
  valence_response        Int?              // 0=Sad, 100=Happy/Uplifting
  arousal_response        Int?              // 0=Calm, 100=Energized
  tension_response        Int?              // 0=Relaxed, 100=Tense
  warmth_response         Int?              // 0=Cold, 100=Warm
  intimacy_response       Int?              // 0=Distant, 100=Personal
  density_response        Int?              // 0=Sparse, 100=Rich/Layered
  groundedness_response   Int?              // 0=Dreamy, 100=Grounded
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model UserTasteProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  valence           Float    @default(0.5)    // happy ↔ sad/melancholic
  arousal           Float    @default(0.5)    // calm ↔ energetic/intense
  tension           Float    @default(0.5)    // resolved/peaceful ↔ unresolved/tense
  warmth            Float    @default(0.5)    // cold/distant ↔ warm/intimate
  intimacy          Float    @default(0.5)    // exposed ↔ personal/private
  density           Float    @default(0.5)    // sparse/minimal ↔ rich/full
  groundedness      Float    @default(0.5)    // escapist ↔ grounded/real
  
  // ─────────────────────────────────────────────────────────────────────
  // PERCEPTION BIAS LAYER (7D - how user emotionally reinterprets albums)
  // 
  // Represents: surveyResponse - intrinsicEmbedding
  // 
  // These capture the user's unique emotional interpretation patterns.
  // They should NOT override intrinsic embeddings, but gently shift them.
  // 
  // Example:
  // - Album has intrinsic warmth = 0.2 (cold)
  // - User perceives warmth = 0.8 (warm)
  // - Bias = +0.6 (user adds warmth to cold albums)
  // - Interpretation: "This user emotionally interprets even cold music as warmer"
  // ─────────────────────────────────────────────────────────────────────
  bias_valence      Float    @default(0.0)    // User's valence interpretation offset
  bias_arousal      Float    @default(0.0)    // User's arousal interpretation offset
  bias_tension      Float    @default(0.0)    // User's tension interpretation offset
  bias_warmth       Float    @default(0.0)    // User's warmth interpretation offset
  bias_intimacy     Float    @default(0.0)    // User's intimacy interpretation offset
  bias_density      Float    @default(0.0)    // User's density interpretation offset
  bias_groundedness Float    @default(0.0)    // User's groundedness interpretation offset
  
  albumsAnalyzed    Int      @default(0)   // How many albums went into this profile
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ═════════════════════════════════════════════════════════════════════════
// ALBUM EMOTIONAL EMBEDDING
// 
// Represents the intrinsic emotional properties of an album.
// Not user-specific - this is the general emotional profile learned from
// audio features, collaborative signals, and (optionally) aggregate survey data.
// 
// Used to:
// - Find emotionally similar albums in 13D space
// - Build user embeddings from surveyed albums
// - Compute contextual recommendations
// ═════════════════════════════════════════════════════════════════════════
model AlbumEmotionalEmbedding {
  id                  String   @id @default(cuid())
  
  albumId             String   @unique
  album               Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  // ─────────────────────────────────────────────────────────────────────
  // 13D INTRINSIC EMOTIONAL EMBEDDING (0-1 scale)
  // These represent general emotional properties of the album.
  // Derived from audio features + optional survey aggregation.
  // ─────────────────────────────────────────────────────────────────────
  
  // Psychological Core (VAD-based)
  valence             Float                   // happy ↔ sad
  arousal             Float                   // calm ↔ energetic
  tension             Float                   // peaceful ↔ tense
  
  // Atmospheric (music-specific)
  warmth              Float                   // cold ↔ warm
  intimacy            Float                   // exposed ↔ intimate
  density             Float                   // sparse ↔ rich
  groundedness        Float                   // escapist ↔ grounded
  
  // ─────────────────────────────────────────────────────────────────────
  // METADATA & QUALITY
  // ─────────────────────────────────────────────────────────────────────
  
  // How this embedding was derived
  derivedFrom         String   @default("audioFeatures")  // "audioFeatures" | "surveys" | "collaborative" | "hybrid"
  
  // Confidence in this embedding (0-1)
  // High: well-known albums with lots of data
  // Low: niche albums, few listeners
  confidence          Float    @default(0.5)
  
  // ─────────────────────────────────────────────────────────────────────
  // LAST.FM SEMANTIC ENRICHMENT
  // Stores community tag data used to influence the embedding.
  // Tags are fetched once per album and blended into the 13D embedding.
  // ─────────────────────────────────────────────────────────────────────
  
  tags                Json?                // Array of { tag: string, count: number }
  enrichmentStatus    String?  @default("pending")  // "enriched" | "pending" | "failed-lastfm" | "audio-only"
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([albumId])
}

// ═════════════════════════════════════════════════════════════════════════
// RECOMMENDATION FEEDBACK
// 
// Tracks what happens when recommendations are given.
// Essential for validation and behavioral learning.
// 
// Stored when recommendation is generated, updated when user listens.
// ═════════════════════════════════════════════════════════════════════════
model RecommendationFeedback {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId             String
  album               Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  recommendationId    String   // Reference to Recommendation table
  
  // ─────────────────────────────────────────────────────────────────────
  // LISTENING BEHAVIOR (updated when user listens)
  // ─────────────────────────────────────────────────────────────────────
  listeningDuration   Int?     // seconds
  completed           Boolean? // did user finish album?
  skipped             Boolean? // did user skip?
  saved               Boolean? // did user favorite?
  
  // ─────────────────────────────────────────────────────────────────────
  // CONTEXT AT TIME OF RECOMMENDATION
  // Used to correlate: does context actually improve recommendations?
  // ─────────────────────────────────────────────────────────────────────
  contextData         Json     // { temperature, humidity, cloudiness, timeOfDay, season, ... }
  
  // User's reported mood/context when recommendation was made (optional)
  userReportedContext String?  // "focus", "relaxation", "walking", "nighttime", etc.
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId, recommendationId])
  @@index([userId, createdAt])
  @@index([albumId])
}

